# Environment: development | production
NODE_ENV=development

# API Configuration
PORT=5000
FRONTEND_URL=http://localhost:5173

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dairy-manager?retryWrites=true&w=majority
MONGODB_RECONNECT_DELAY_MS=5000

# Admin Credentials (for login endpoint)
ADMIN_EMAIL=admin@dairy.local
ADMIN_PASSWORD=your_secure_password_here

# JWT Authentication
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
CORS_ALLOWED_ORIGINS=http://localhost:5173

# WhatsApp Automation (Free via whatsapp-web.js)
WHATSAPP_ENABLED=true
WHATSAPP_AUTO_SEND=true
WHATSAPP_PROVIDER=whatsapp-web
WHATSAPP_SESSION_NAME=dairy-manager-alt
WHATSAPP_FALLBACK_SESSION_SUFFIX=alt
WHATSAPP_DEFAULT_COUNTRY_CODE=91

# Database Type
DB_TYPE=mongodb
